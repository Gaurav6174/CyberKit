# CyberKit Environment Variables

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/cyberkit

# Redis
REDIS_URL=redis://localhost:6379

# NextAuth
NEXTAUTH_SECRET=<32-byte-random-hex-string>
NEXTAUTH_URL=http://localhost:3000

# Encryption (for API key storage)
ENCRYPTION_KEY=<32-byte-aes-key>

# OAuth Providers
GITHUB_CLIENT_ID=<github-oauth-client-id>
GITHUB_CLIENT_SECRET=<github-oauth-client-secret>

# External API Keys (optional - users can also add their own in settings)
SHODAN_API_KEY=
VIRUSTOTAL_API_KEY=
HIBP_API_KEY=
NVD_API_KEY=

# Socket.IO
SOCKET_SECRET=<socket-auth-secret>

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
